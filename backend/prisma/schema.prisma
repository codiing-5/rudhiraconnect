datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String             @id @default(uuid())
  name             String
  email            String             @unique
  password         String
  phone            String
  college          String
  district         String
  bloodGroup       String?            // Optional blood group
  role             String             @default("USER") // "USER" | "ADMIN"
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  
  eligibilityChecks EligibilityCheck[]
  registrations    CampRegistration[]
  donations        Donation[]
  certificates     Certificate[]
  notifications    Notification[]
  
  // Relations for Blood Buddy referral system
  sentInvites      BloodBuddy[]       @relation("InviterRelation")
  receivedInvites  BloodBuddy[]       @relation("InviteeRelation")
}

model EligibilityCheck {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age              Int
  weight           Float
  lastDonation     DateTime?
  hemoglobin       Float?
  result           String   // "ELIGIBLE" | "TEMPORARY_DEFERRAL" | "PERMANENT_DEFERRAL"
  reason           String?  // Explanation for deferral
  nextEligibleDate DateTime?
  createdAt        DateTime @default(now())
}

model BloodCamp {
  id               String             @id @default(uuid())
  title            String
  description      String
  location         String
  district         String
  date             DateTime
  time             String             // e.g. "09:00 AM - 04:00 PM"
  organizer        String
  latitude         Float
  longitude        Float
  registrations    CampRegistration[]
  donations        Donation[]
}

model CampRegistration {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campId       String
  camp         BloodCamp @relation(fields: [campId], references: [id], onDelete: Cascade)
  status       String    @default("REGISTERED") // "REGISTERED" | "ATTENDED" | "CANCELLED"
  registeredAt DateTime  @default(now())

  @@unique([userId, campId])
}

model Donation {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campId         String?
  camp           BloodCamp?   @relation(fields: [campId], references: [id], onDelete: SetNull)
  donationDate   DateTime
  bloodBank      String       // The clinic or hospital where the blood was stored
  certificateUrl String?
  status         String       @default("PENDING") // "PENDING" | "VERIFIED" | "REJECTED"
  createdAt      DateTime     @default(now())
  certificate    Certificate?
}

model Certificate {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  donationId     String   @unique
  donation       Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  certificateUrl String   // Base64 encoded or dynamic layout identifier
  issuedDate     DateTime @default(now())
}

model AwarenessArticle {
  id          String   @id @default(uuid())
  title       String
  content     String
  image       String?  // Optional image URL/base64
  video       String?  // Optional video URL
  category    String   // "GUIDELINE" | "STORY" | "QUIZ" | "NEWS"
  publishedAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BloodBuddy {
  id         String    @id @default(uuid())
  inviterId  String
  inviter    User      @relation("InviterRelation", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeId  String
  invitee    User      @relation("InviteeRelation", fields: [inviteeId], references: [id], onDelete: Cascade)
  status     String    @default("PENDING") // "PENDING" | "JOINED"
  joinedDate DateTime?
  
  @@unique([inviterId, inviteeId])
}

model Leaderboard {
  id               String @id @default(uuid())
  college          String
  totalDonations   Int    @default(0)
  bloodBuddyPoints Int    @default(0)
  month            Int
  year             Int

  @@unique([college, month, year])
}
